          "ioValue": "{   \"keelK\": [     0,     0   ],   \"length\": 1000,   \"transom\": {     \"x\": 0,     \"depthTop\": 15.827178955078125,     \"dDepthBot\": 174.14390563964844,     \"transomRake\": 0   },   \"sheerPlan\": [     {       \"w\": [         0.02005069538698358,         0.9799493046130164       ],       \"y\": 34.44051742553711,       \"dx\": 0     },     {       \"w\": [         0.999,         0.0010000000000000009       ],       \"y\": 131.89802169799805,       \"dx\": 503.2904815673828     },     {       \"w\": [         0.001,         0.999       ],       \"y\": 0,       \"dx\": 496.7095184326172     }   ],   \"sheerTrim\": [     {       \"k\": 0,       \"dx\": 0,       \"depth\": 54.2501163482666     },     {       \"k\": 0,       \"dx\": 568.9690399169922,       \"depth\": 28.825626373291016     },     {       \"k\": 0,       \"dx\": 436.4519500732422,       \"depth\": 15.054216384887695     }   ],   \"templates\": [     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": 0.38807787214005884,         \"dd\": 60.653538022722515       },       {         \"k\": 0,         \"n\": 3.4492675236293167,         \"dd\": 37.50021280561174       },       {         \"k\": 0,         \"n\": 81.51094981602259,         \"dd\": 45.91858209882464       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": 1.918678283691392,         \"dd\": 90.50065939767019       },       {         \"k\": 0,         \"n\": 5.745223999023423,         \"dd\": 18.367383684430806       },       {         \"k\": 0,         \"n\": 53.95976257324219,         \"dd\": 16.0715389251709       }     ]   ],   \"waterline\": 110,   \"deckRakeDeg\": 0 }",
          "currentEquation": "{   \"keelK\": [     1,     0,     1   ],   \"length\": 1000,   \"transom\": {     \"x\": 0,     \"depthTop\": 41.50490760803223,     \"dDepthBot\": 151.19446754455566,     \"transomRake\": 0   },   \"sheerPlan\": [     {       \"w\": [         0.964651285591772,         0.035348714408227955,         0       ],       \"y\": -1.80450439453125,       \"dx\": 0     },     {       \"w\": [         0.7486291655612998,         0.2513708258919268,         8.546773481274663e-9       ],       \"y\": 24.07421112060547,       \"dx\": 105.3428840637207     },     {       \"w\": [         0.21106577727754236,         0.7889236729993971,         0.000010549723060471194       ],       \"y\": 67.2055435180664,       \"dx\": 207.03035354614258     },     {       \"w\": [         0.001,         0.9980000000000001,         0.0009999999999998899       ],       \"y\": 87.41537094116211,       \"dx\": 184.7177505493164     },     {       \"w\": [         0.000999974371984932,         0.7656963090007971,         0.23330371662721794       ],       \"y\": 65.04901885986328,       \"dx\": 177.5855255126953     },     {       \"w\": [         0.0009999996180250232,         0.38114208681259754,         0.6178579135693775       ],       \"y\": 34.8570442199707,       \"dx\": 170.36880493164062     },     {       \"w\": [         0.00100000000030143,         0.047281919751120095,         0.9517180802485785       ],       \"y\": -5.360698699951172,       \"dx\": 181.4720916748047     }   ],   \"sheerTrim\": [     {       \"k\": 0,       \"dx\": 0,       \"depth\": 0     },     {       \"k\": 0,       \"dx\": 256.3025665283203,       \"depth\": 31.7159366607666     },     {       \"k\": 0,       \"dx\": 323.4849548339844,       \"depth\": 44.655303955078125     },     {       \"k\": 0,       \"dx\": 420.5304718017578,       \"depth\": 29.559402465820312     }   ],   \"templates\": [     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 13.414994648524683,         \"dd\": 40.27403504507882       },       {         \"k\": 0,         \"n\": 32.124430792672285,         \"dd\": 79.51480756487165       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 4.0603324345179885,         \"dd\": 68.33806637355259       },       {         \"k\": 0,         \"n\": 233.24999237060547,         \"dd\": 53.009864262172144       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 1,         \"n\": 7.178508486066534,         \"dd\": 57.42429379054478       },       {         \"k\": 0,         \"n\": 5.619420460292261,         \"dd\": 70.16011183602468       }     ]   ],   \"waterline\": 60,   \"deckRakeDeg\": 0 }"
